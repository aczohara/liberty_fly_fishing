# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real API keys.

# Google Drive API key
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or use an existing one)
# 3. Enable the "Google Drive API" for that project
# 4. Go to Credentials → Create Credentials → API key
# 5. Restrict the key:
#    - API restrictions: Google Drive API only
#    - HTTP referrer restrictions: your domain (e.g. libertyflyfishing.com/*)
# 6. Paste the key below
VITE_GOOGLE_API_KEY=your_api_key_here

# ─── Important: Drive folder sharing settings ─────────────────────────────────
# The Drive API can only list folder contents for PUBLICLY ACCESSIBLE folders.
# In Google Drive, open each folder → Share → change from "Anyone with the link"
# to "Anyone on the internet can view". This does NOT make files discoverable by
# search engines — it just allows the API to list them with the API key.
# ──────────────────────────────────────────────────────────────────────────────
